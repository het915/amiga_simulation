<?xml version="1.0"?>
<model>
  <name>soybean_plant</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>
  <author>
    <name>het915</name>
  </author>
  <description>
    Procedurally generated soybean plant meshes from the Helios framework
    (UC Davis) at three growth stages (30d, 40d, 50d). Meshes decimated in
    Blender for real-time simulation.
  </description>
</model>
