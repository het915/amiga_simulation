<?xml version="1.0"?>
<robot name="amiga">

  <!-- ============================================================ -->
  <!-- MATERIALS                                                     -->
  <!-- ============================================================ -->
  <material name="dark_metal">
    <color rgba="0.20 0.20 0.20 1.0"/>
  </material>
  <material name="light_metal">
    <color rgba="0.95 0.95 0.95 1.0"/>
  </material>
  <material name="frame_metal">
    <color rgba="0.45 0.45 0.45 1.0"/>
  </material>
  <material name="rubber_black">
    <color rgba="0.10 0.10 0.10 1.0"/>
  </material>
  <material name="sensor_dark">
    <color rgba="0.15 0.15 0.15 1.0"/>
  </material>

  <!-- ============================================================ -->
  <!-- BASE LINK (main frame structure)                              -->
  <!-- Origin at ground projection. All Z measured from ground.      -->
  <!-- Real Amiga: 1.5" square tube = 0.038m                        -->
  <!-- Ground clearance: 0.612m (24.1 inches)                       -->
  <!-- ============================================================ -->
  <link name="base_link">
    <inertial>
      <mass value="90.0"/>
      <origin xyz="0 0 1.262" rpy="0 0 0"/>
      <inertia ixx="15.0" ixy="0" ixz="0" iyy="13.0" iyz="0" izz="8.0"/>
    </inertial>

    <!-- ========== SIDE RAILS at ground clearance z=0.612 ========== -->
    <visual name="rail_left_outer">
      <origin xyz="0 0.65 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="rail_left_outer_col">
      <origin xyz="0 0.65 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
    </collision>

    <visual name="rail_left_inner">
      <origin xyz="0 0.55 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="rail_left_inner_col">
      <origin xyz="0 0.55 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
    </collision>

    <visual name="rail_right_outer">
      <origin xyz="0 -0.65 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="rail_right_outer_col">
      <origin xyz="0 -0.65 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
    </collision>

    <visual name="rail_right_inner">
      <origin xyz="0 -0.55 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="rail_right_inner_col">
      <origin xyz="0 -0.55 0.612" rpy="0 0 0"/>
      <geometry><box size="1.1 0.038 0.038"/></geometry>
    </collision>

    <!-- ========== VERTICAL UPRIGHTS (8 total, z=0.612 to z=1.912) ========== -->
    <!-- Left outer pair (y=0.65) -->
    <visual name="upright_lo_1">
      <origin xyz="-0.025 0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_lo_1_col">
      <origin xyz="-0.025 0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>
    <visual name="upright_lo_2">
      <origin xyz="0.025 0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_lo_2_col">
      <origin xyz="0.025 0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>

    <!-- Left inner pair (y=0.55) -->
    <visual name="upright_li_1">
      <origin xyz="-0.025 0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_li_1_col">
      <origin xyz="-0.025 0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>
    <visual name="upright_li_2">
      <origin xyz="0.025 0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_li_2_col">
      <origin xyz="0.025 0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>

    <!-- Right inner pair (y=-0.55) -->
    <visual name="upright_ri_1">
      <origin xyz="-0.025 -0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_ri_1_col">
      <origin xyz="-0.025 -0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>
    <visual name="upright_ri_2">
      <origin xyz="0.025 -0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_ri_2_col">
      <origin xyz="0.025 -0.55 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>

    <!-- Right outer pair (y=-0.65) -->
    <visual name="upright_ro_1">
      <origin xyz="-0.025 -0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_ro_1_col">
      <origin xyz="-0.025 -0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>
    <visual name="upright_ro_2">
      <origin xyz="0.025 -0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="upright_ro_2_col">
      <origin xyz="0.025 -0.65 1.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 1.3"/></geometry>
    </collision>

    <!-- ========== MID-HEIGHT SUSPENSION SUPPORT BARS (z=1.0) ========== -->
    <visual name="susp_bar_left">
      <origin xyz="0 0.60 1.0" rpy="0 0 0"/>
      <geometry><box size="0.8 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="susp_bar_left_col">
      <origin xyz="0 0.60 1.0" rpy="0 0 0"/>
      <geometry><box size="0.8 0.038 0.038"/></geometry>
    </collision>
    <visual name="susp_bar_right">
      <origin xyz="0 -0.60 1.0" rpy="0 0 0"/>
      <geometry><box size="0.8 0.038 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="susp_bar_right_col">
      <origin xyz="0 -0.60 1.0" rpy="0 0 0"/>
      <geometry><box size="0.8 0.038 0.038"/></geometry>
    </collision>

    <!-- ========== TOP CROSS BRACES at z=1.912 ========== -->
    <visual name="brace_top_1">
      <origin xyz="-0.075 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="brace_top_1_col">
      <origin xyz="-0.075 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
    </collision>
    <visual name="brace_top_2">
      <origin xyz="-0.025 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="brace_top_2_col">
      <origin xyz="-0.025 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
    </collision>
    <visual name="brace_top_3">
      <origin xyz="0.025 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="brace_top_3_col">
      <origin xyz="0.025 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
    </collision>
    <visual name="brace_top_4">
      <origin xyz="0.075 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="brace_top_4_col">
      <origin xyz="0.075 0 1.912" rpy="0 0 0"/>
      <geometry><box size="0.038 1.3 0.038"/></geometry>
    </collision>

    <!-- ========== ANTENNA POLE (z=1.912 to z=2.612) ========== -->
    <visual name="antenna_pole">
      <origin xyz="0 0 2.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 0.7"/></geometry>
      <material name="frame_metal"/>
    </visual>
    <collision name="antenna_pole_col">
      <origin xyz="0 0 2.262" rpy="0 0 0"/>
      <geometry><box size="0.038 0.038 0.7"/></geometry>
    </collision>
  </link>

  <!-- ============================================================ -->
  <!-- FRONT LEFT: SUSPENSION + FORK + WHEEL                        -->
  <!-- ============================================================ -->
  <link name="fl_fork_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <inertia ixx="0.094" ixy="0" ixz="0" iyy="0.115" iyz="0" izz="0.069"/>
    </inertial>
    <visual name="fl_fork_vis">
      <origin xyz="0 0 -0.396" rpy="1.5708 0 3.14159"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/smart_fork.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="fl_fork_col">
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <geometry><box size="0.33 0.15 0.41"/></geometry>
    </collision>
  </link>

  <joint name="fl_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="fl_fork_link"/>
    <origin xyz="0.5 0.6 0.612" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.025" upper="0.025" effort="5000" velocity="0.5"/>
    <dynamics damping="1500" friction="50"/>
  </joint>

  <link name="front_left_wheel_link">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.19" iyz="0" izz="0.10"/>
    </inertial>
    <visual name="fl_wheel_vis">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/wheel.stl"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <collision name="fl_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.216" length="0.103"/></geometry>
    </collision>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="fl_fork_link"/>
    <child link="front_left_wheel_link"/>
    <origin xyz="0 0 -0.396" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="5.0"/>
    <limit effort="140" velocity="12"/>
  </joint>

  <!-- ============================================================ -->
  <!-- FRONT RIGHT: SUSPENSION + FORK + WHEEL                       -->
  <!-- ============================================================ -->
  <link name="fr_fork_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <inertia ixx="0.094" ixy="0" ixz="0" iyy="0.115" iyz="0" izz="0.069"/>
    </inertial>
    <visual name="fr_fork_vis">
      <origin xyz="0 0 -0.396" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/smart_fork.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="fr_fork_col">
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <geometry><box size="0.33 0.15 0.41"/></geometry>
    </collision>
  </link>

  <joint name="fr_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="fr_fork_link"/>
    <origin xyz="0.5 -0.6 0.612" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.025" upper="0.025" effort="5000" velocity="0.5"/>
    <dynamics damping="1500" friction="50"/>
  </joint>

  <link name="front_right_wheel_link">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.19" iyz="0" izz="0.10"/>
    </inertial>
    <visual name="fr_wheel_vis">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/wheel.stl"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <collision name="fr_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.216" length="0.103"/></geometry>
    </collision>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="fr_fork_link"/>
    <child link="front_right_wheel_link"/>
    <origin xyz="0 0 -0.396" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="5.0"/>
    <limit effort="140" velocity="12"/>
  </joint>

  <!-- ============================================================ -->
  <!-- REAR LEFT: SUSPENSION + FORK + WHEEL                         -->
  <!-- ============================================================ -->
  <link name="rl_fork_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <inertia ixx="0.094" ixy="0" ixz="0" iyy="0.115" iyz="0" izz="0.069"/>
    </inertial>
    <visual name="rl_fork_vis">
      <origin xyz="0 0 -0.396" rpy="1.5708 0 3.14159"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/smart_fork.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="rl_fork_col">
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <geometry><box size="0.33 0.15 0.41"/></geometry>
    </collision>
  </link>

  <joint name="rl_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="rl_fork_link"/>
    <origin xyz="-0.5 0.6 0.612" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.025" upper="0.025" effort="5000" velocity="0.5"/>
    <dynamics damping="1500" friction="50"/>
  </joint>

  <link name="rear_left_wheel_link">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.19" iyz="0" izz="0.10"/>
    </inertial>
    <visual name="rl_wheel_vis">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/wheel.stl"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <collision name="rl_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.216" length="0.103"/></geometry>
    </collision>
  </link>

  <joint name="rear_left_wheel_joint" type="continuous">
    <parent link="rl_fork_link"/>
    <child link="rear_left_wheel_link"/>
    <origin xyz="0 0 -0.396" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="5.0"/>
    <limit effort="140" velocity="12"/>
  </joint>

  <!-- ============================================================ -->
  <!-- REAR RIGHT: SUSPENSION + FORK + WHEEL                        -->
  <!-- ============================================================ -->
  <link name="rr_fork_link">
    <inertial>
      <mass value="5.0"/>
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <inertia ixx="0.094" ixy="0" ixz="0" iyy="0.115" iyz="0" izz="0.069"/>
    </inertial>
    <visual name="rr_fork_vis">
      <origin xyz="0 0 -0.396" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/smart_fork.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="rr_fork_col">
      <origin xyz="0 0 -0.2" rpy="0 0 0"/>
      <geometry><box size="0.33 0.15 0.41"/></geometry>
    </collision>
  </link>

  <joint name="rr_suspension_joint" type="prismatic">
    <parent link="base_link"/>
    <child link="rr_fork_link"/>
    <origin xyz="-0.5 -0.6 0.612" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.025" upper="0.025" effort="5000" velocity="0.5"/>
    <dynamics damping="1500" friction="50"/>
  </joint>

  <link name="rear_right_wheel_link">
    <inertial>
      <mass value="8.0"/>
      <inertia ixx="0.10" ixy="0" ixz="0" iyy="0.19" iyz="0" izz="0.10"/>
    </inertial>
    <visual name="rr_wheel_vis">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/wheel.stl"/></geometry>
      <material name="rubber_black"/>
    </visual>
    <collision name="rr_wheel_col">
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.216" length="0.103"/></geometry>
    </collision>
  </link>

  <joint name="rear_right_wheel_joint" type="continuous">
    <parent link="rr_fork_link"/>
    <child link="rear_right_wheel_link"/>
    <origin xyz="0 0 -0.396" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="5.0"/>
    <limit effort="140" velocity="12"/>
  </joint>

  <!-- ============================================================ -->
  <!-- OAK-D CAMERA (on antenna pole)                                -->
  <!-- ============================================================ -->
  <link name="oak_link">
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual name="oak_visual">
      <origin xyz="0 0 0" rpy="3.14159 -0.5236 -1.5708"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/oak-d_simplified.stl"/></geometry>
      <material name="sensor_dark"/>
    </visual>
    <visual name="camera_housing">
      <origin xyz="-0.08 -0.022 -0.04" rpy="3.14159 -0.5236 -1.5708"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/camera_housing.stl"/></geometry>
      <material name="dark_metal"/>
    </visual>
    <visual name="camera_bracket">
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/camera_bracket.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="oak_col">
      <origin xyz="0 0 0" rpy="3.14159 -0.5236 -1.5708"/>
      <geometry><box size="0.12 0.05 0.04"/></geometry>
    </collision>
  </link>

  <joint name="oak_joint" type="fixed">
    <parent link="base_link"/>
    <child link="oak_link"/>
    <origin xyz="0 0 2.112" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- GPS ANTENNA (top of antenna pole)                             -->
  <!-- ============================================================ -->
  <link name="gps_link">
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
    <visual name="gps_visual">
      <geometry><mesh filename="package://virtual_maize_field/models/amiga/meshes/gps_antenna.stl"/></geometry>
      <material name="light_metal"/>
    </visual>
    <collision name="gps_col">
      <geometry><cylinder radius="0.075" length="0.066"/></geometry>
    </collision>
  </link>

  <joint name="gps_joint" type="fixed">
    <parent link="base_link"/>
    <child link="gps_link"/>
    <origin xyz="0 0 2.612" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- IMU (on top brace, invisible)                                 -->
  <!-- ============================================================ -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 1.912" rpy="0 0 0"/>
  </joint>

</robot>
