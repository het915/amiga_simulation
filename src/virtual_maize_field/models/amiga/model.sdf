<?xml version="1.0"?>
<sdf version="1.9">
  <model name="amiga">
    <static>false</static>

    <!-- ============================================================ -->
    <!-- BASE LINK (main frame)                                        -->
    <!-- Origin at ground. 1.5" tube = 0.038m. Clearance = 0.612m.    -->
    <!-- ============================================================ -->
    <link name="base_link">
      <inertial>
        <mass>90.0</mass>
        <pose>0 0 1.262 0 0 0</pose>
        <inertia>
          <ixx>15.0</ixx> <ixy>0</ixy> <ixz>0</ixz>
          <iyy>13.0</iyy> <iyz>0</iyz>
          <izz>8.0</izz>
        </inertia>
      </inertial>

      <!-- Side rails at z=0.612 -->
      <visual name="rail_lo"><pose>0 0.65 0.612 0 0 0</pose>
        <geometry><box><size>1.1 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
      </visual>
      <collision name="rail_lo_col"><pose>0 0.65 0.612 0 0 0</pose><geometry><box><size>1.1 0.038 0.038</size></box></geometry></collision>

      <visual name="rail_li"><pose>0 0.55 0.612 0 0 0</pose>
        <geometry><box><size>1.1 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
      </visual>
      <collision name="rail_li_col"><pose>0 0.55 0.612 0 0 0</pose><geometry><box><size>1.1 0.038 0.038</size></box></geometry></collision>

      <visual name="rail_ro"><pose>0 -0.65 0.612 0 0 0</pose>
        <geometry><box><size>1.1 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
      </visual>
      <collision name="rail_ro_col"><pose>0 -0.65 0.612 0 0 0</pose><geometry><box><size>1.1 0.038 0.038</size></box></geometry></collision>

      <visual name="rail_ri"><pose>0 -0.55 0.612 0 0 0</pose>
        <geometry><box><size>1.1 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material>
      </visual>
      <collision name="rail_ri_col"><pose>0 -0.55 0.612 0 0 0</pose><geometry><box><size>1.1 0.038 0.038</size></box></geometry></collision>

      <!-- 8 Vertical uprights (z=0.612 to 1.912, center=1.262, height=1.3) -->
      <visual name="up_lo1"><pose>-0.025 0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_lo1_c"><pose>-0.025 0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>
      <visual name="up_lo2"><pose>0.025 0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_lo2_c"><pose>0.025 0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>

      <visual name="up_li1"><pose>-0.025 0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_li1_c"><pose>-0.025 0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>
      <visual name="up_li2"><pose>0.025 0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_li2_c"><pose>0.025 0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>

      <visual name="up_ri1"><pose>-0.025 -0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_ri1_c"><pose>-0.025 -0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>
      <visual name="up_ri2"><pose>0.025 -0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_ri2_c"><pose>0.025 -0.55 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>

      <visual name="up_ro1"><pose>-0.025 -0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_ro1_c"><pose>-0.025 -0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>
      <visual name="up_ro2"><pose>0.025 -0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="up_ro2_c"><pose>0.025 -0.65 1.262 0 0 0</pose><geometry><box><size>0.038 0.038 1.3</size></box></geometry></collision>

      <!-- Mid-height suspension support bars at z=1.0 -->
      <visual name="susp_l"><pose>0 0.60 1.0 0 0 0</pose><geometry><box><size>0.8 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="susp_l_c"><pose>0 0.60 1.0 0 0 0</pose><geometry><box><size>0.8 0.038 0.038</size></box></geometry></collision>
      <visual name="susp_r"><pose>0 -0.60 1.0 0 0 0</pose><geometry><box><size>0.8 0.038 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="susp_r_c"><pose>0 -0.60 1.0 0 0 0</pose><geometry><box><size>0.8 0.038 0.038</size></box></geometry></collision>

      <!-- 4 Top cross braces at z=1.912 -->
      <visual name="br1"><pose>-0.075 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="br1_c"><pose>-0.075 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry></collision>
      <visual name="br2"><pose>-0.025 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="br2_c"><pose>-0.025 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry></collision>
      <visual name="br3"><pose>0.025 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="br3_c"><pose>0.025 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry></collision>
      <visual name="br4"><pose>0.075 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="br4_c"><pose>0.075 0 1.912 0 0 0</pose><geometry><box><size>0.038 1.3 0.038</size></box></geometry></collision>

      <!-- Antenna pole (z=1.912 to 2.612) -->
      <visual name="ant"><pose>0 0 2.262 0 0 0</pose><geometry><box><size>0.038 0.038 0.7</size></box></geometry>
        <material><ambient>0.35 0.35 0.35 1</ambient><diffuse>0.45 0.45 0.45 1</diffuse><specular>0.3 0.3 0.3 1</specular></material></visual>
      <collision name="ant_c"><pose>0 0 2.262 0 0 0</pose><geometry><box><size>0.038 0.038 0.7</size></box></geometry></collision>
    </link>

    <!-- ============================================================ -->
    <!-- FRONT LEFT: SUSPENSION + FORK + WHEEL                        -->
    <!-- ============================================================ -->
    <link name="fl_fork_link">
      <pose relative_to="fl_suspension_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>5.0</mass>
        <pose>0 0 -0.2 0 0 0</pose>
        <inertia><ixx>0.094</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.115</iyy><iyz>0</iyz><izz>0.069</izz></inertia>
      </inertial>
      <visual name="fl_fork_v"><pose>0 0 -0.396 1.5708 0 3.14159</pose>
        <geometry><mesh><uri>meshes/smart_fork.stl</uri></mesh></geometry>
        <material><ambient>0.90 0.90 0.90 1</ambient><diffuse>0.95 0.95 0.95 1</diffuse><specular>0.5 0.5 0.5 1</specular></material></visual>
      <collision name="fl_fork_c"><pose>0 0 -0.2 0 0 0</pose><geometry><box><size>0.33 0.15 0.41</size></box></geometry></collision>
    </link>

    <joint name="fl_suspension_joint" type="prismatic">
      <parent>base_link</parent>
      <child>fl_fork_link</child>
      <pose relative_to="base_link">0.5 0.6 0.612 0 0 0</pose>
      <axis>
        <xyz>0 0 1</xyz>
        <dynamics><damping>1500</damping><friction>50</friction><spring_stiffness>44000</spring_stiffness><spring_reference>0.0</spring_reference></dynamics>
        <limit><lower>-0.025</lower><upper>0.025</upper><effort>5000</effort><velocity>0.5</velocity></limit>
      </axis>
    </joint>

    <link name="front_left_wheel_link">
      <pose relative_to="front_left_wheel_joint">0 0 0 0 0 0</pose>
      <inertial>
        <mass>8.0</mass>
        <inertia><ixx>0.10</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.19</iyy><iyz>0</iyz><izz>0.10</izz></inertia>
      </inertial>
      <visual name="fl_wh_v"><pose>0 0 0 1.5708 0 0</pose>
        <geometry><mesh><uri>meshes/wheel.stl</uri></mesh></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse><specular>0.15 0.15 0.15 1</specular></material></visual>
      <collision name="fl_wh_c">
        <geometry><sphere><radius>0.216</radius></sphere></geometry>
        <surface><friction><ode><mu>1.5</mu><mu2>1.5</mu2></ode></friction>
        <contact><ode><kp>1e7</kp><kd>1000</kd><min_depth>0.001</min_depth></ode></contact></surface></collision>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <parent>fl_fork_link</parent>
      <child>front_left_wheel_link</child>
      <pose relative_to="fl_fork_link">0 0 -0.396 0 0 0</pose>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics><damping>5.0</damping></dynamics>
        <limit><lower>-1e16</lower><upper>1e16</upper><effort>140</effort></limit>
      </axis>
    </joint>

